FROM node:20-alpine AS base

WORKDIR /app

RUN apk add --no-cache tini wget

EXPOSE 9000

FROM base AS deps

COPY apps/backend/package.json ./
RUN npm install -g pnpm@10.11.1
RUN --mount=type=cache,target=/root/.local/share/pnpm/store pnpm install --frozen-lockfile

COPY apps/backend/tsconfig.json apps/backend/medusa-config.ts ./
COPY apps/backend/.env.template ./apps/backend/.env

FROM deps AS build

COPY apps/backend/src ./src
RUN pnpm build

FROM base AS runner

RUN addgroup --system --gid 1001 medusa && \
    adduser --system --uid 1001 medusa

COPY --from=deps --chown=medusa:medusa /app/node_modules ./node_modules
COPY --from=build --chown=medusa:medusa /app/dist ./dist
COPY --from=build --chown=medusa:medusa /app/medusa-config.ts ./
COPY --chown=medusa:medusa apps/backend/package.json ./

RUN mkdir -p /app/uploads && chown medusa:medusa /app/uploads

VOLUME /app/uploads

USER medusa

HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:9000/health || exit 1

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["npm", "run", "start"]
